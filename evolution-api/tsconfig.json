{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./",
    "outDir": "./dist",

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "incremental": true,
    "removeComments": true,
    "noEmitOnError": true,

    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",

    "paths": {
      "@api/*": ["src/api/*"],
      "@cache/*": ["src/cache/*"],
      "@config/*": ["src/config/*"],
      "@exceptions": ["src/exceptions"],
      "@libs/*": ["src/libs/*"],
      "@utils/*": ["src/utils/*"],
      "@validate/*": ["src/validate/*"]
    }
  },

  "include": [
    "src/**/*",
    "src/**/*.json",
    "tsup.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "test",
    "prisma"
  ]
}